{
  "name": "Retail Corporate Dark Blue",
  "dataColors": [
    "#2F80ED",
    "#27AE60",
    "#F2994A",
    "#EB5757",
    "#56CCF2",
    "#9B51E0",
    "#BDBDBD",
    "#6FCF97"
  ],
  "background": "#F5F7FB",
  "foreground": "#1F2937",
  "tableAccent": "#2F80ED",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "fontColor": { "solid": { "color": "#1F2937" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#374151" } },
            "fontSize": 10
          }
        ],
        "background": [
          {
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#E5E7EB" } },
            "radius": 4
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#0F2A43" } },
            "fontSize": 22,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#6B7280" } },
            "fontSize": 10
          }
        ]
      }
    }
  }
}
